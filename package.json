{
  "name": "@inneropen/marvin-renderers-core",
  "version": "1.1.0-next.2",
  "description": "Core renderer components for Marvin CMS — semantic Astro components for system entry types",
  "type": "module",
  "exports": {
    "./logic": {
      "types": "./dist/logic/index.d.ts",
      "import": "./dist/logic/index.js"
    },
    "./astro": "./src/astro/index.ts",
    "./astro/registry": "./src/astro/registry.ts",
    "./astro/integration": "./src/astro/integration.ts",
    "./astro/renderers/*": "./src/astro/renderers/*"
  },
  "files": [
    "dist",
    "src/astro"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@inneropen/marvin-sdk": "^2.0.0",
    "astro": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "devDependencies": {
    "@inneropen/marvin-sdk": "^2.0.0-next.20",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@types/node": "^26.1.1",
    "astro": "^5.0.0",
    "semantic-release": "^24.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inneropen/marvin-renderers-core.git"
  }
}
