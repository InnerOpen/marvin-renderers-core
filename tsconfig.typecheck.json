{
  // Typecheck config: the same compiler options as the build, but widened to cover
  // tests/ as well. `tsconfig.json` stays scoped to src/ so it keeps describing what
  // ships; this file is what `npm run typecheck` uses.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
