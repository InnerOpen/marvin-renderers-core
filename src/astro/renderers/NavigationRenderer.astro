---
import type { MarvinEntry } from '@inneropen/marvin-sdk';
import { extractField } from '../../logic/resolve.js';

interface Props {
  entry: MarvinEntry;
  config?: Record<string, unknown>;
  class?: string;
}

const { entry, config, class: className } = Astro.props;

const href = extractField<string>(entry, 'href') ?? '#';
const openInNewTab = extractField<boolean>(entry, 'openInNewTab') ?? false;
const typeSlug = entry.entryTypeInfo?.slug ?? 'navigation-item';
---

<a
  data-renderer="navigation"
  data-entry-type={typeSlug}
  class={className}
  href={href}
  {...openInNewTab ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  {entry.title}
  <slot />
</a>
